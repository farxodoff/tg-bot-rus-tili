BOT_TOKEN=telegram_bot_tokeningizni_shu_yerga_qoying

# Google Gemini API kaliti — BEPUL: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=gemini_api_kalitingizni_shu_yerga_qoying
GEMINI_MODEL=gemini-2.5-flash

# edge-tts (bepul, Microsoft Edge ovozlari) — kalit kerak emas
TTS_VOICE=ru-RU-DmitryNeural

DB_PATH=data/bot.sqlite3

THROTTLE_RATE=1.0
DAILY_WORD_HOUR=9
DAILY_WORD_MINUTE=0
TIMEZONE=Asia/Tashkent

ADMIN_IDS=

# Webhook rejimi (ixtiyoriy). Bo'sh bo'lsa polling ishlatiladi.
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_SECRET=
